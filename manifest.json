{
  "manifest_version": 3,
  "name": "MoneyMan Chat Enhancer",
  "version": "1.0.2",
  "description": "Улучшает чат оператора: стилизация сообщений, вложений, мульти-меню, перенос длинных ID",
  "permissions": [],
  "update_url": "https://raw.githubusercontent.com/testkonstantinmishchenko-spec/moneyman-chat-enhancer/main/updates.xml",
  "content_scripts": [
    {
      "matches": ["https://chat.moneyman.ru/operator/chat/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}